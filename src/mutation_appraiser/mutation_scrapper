import requests
import json
import re
from pathlib import Path
from bs4 import BeautifulSoup

RAW_FILE = Path('src/data/mutations_raw.json')
CLEAN_FILE = Path('src/data/mutations.json')

API_URL = "https://fischipedia.org/w/api.php"
params = {
    "action": "parse",
    "page": "Mutations",
    "prop": "text",
    "format": "json"
}
headers = {
    "User-Agent": "FischAppraiser/1.0"
}

# Methods
def fetch_and_save():
    response = requests.get(API_URL, params=params, headers=headers)
    response.raise_for_status()
    data = response.json()
    # Save raw API response
    #with open("src/data/mutations_raw.json", "w", encoding="utf-8") as f:
        #json.dump(data, f, indent=2, ensure_ascii=False)
    #print("Saved mutations_raw.json")
    return data

def extract_hex_color(soup,name:str):
    selector = f".mutation-{name.lower()}"

    for style in soup.find_all("style"):
        if not style.string:
            continue

        css = style.string

        # find the block for this selector
        pattern = rf"{re.escape(selector)}\s*\{{(.*?)\}}"
        match = re.search(pattern, css, re.DOTALL)

        if match:
            block = match.group(1)

            # extract hex
            hex_match = re.search(r"#([0-9a-fA-F]{3,6})", block)
            if hex_match:
                return f"#{hex_match.group(1)}"

    return None

def extract_mutations(raw):
    # HTML is inside this field
    html = raw["parse"]["text"]["*"]
    soup = BeautifulSoup(html, "html.parser")
    table = soup.find("table", {"id": "mutation-table-1"})
    if not table:
        raise Exception("Mutation table not found")
    tbody = table.find("tbody")

    rows = []
    for tr in tbody.find_all("tr")[2:]: # skip first two as they are just starters
        #Name
        cell = tr.find("td", class_='name')
        if not cell:
            continue
        
        name = cell.get_text(strip="True")
        color = extract_hex_color(soup,name)
        #Value
        cell = tr.find("td", class_='value')
        if not cell:
            continue
        
        value = cell.get_text(strip="True")

        #Appraisable (true/false)
        cell = tr.find('td',class_='appraisable')
        if not cell:
            continue
        isAppraisable = cell.get("title","").strip().lower() == 'yes'
        if not isAppraisable:
            continue

        rows.append({
            "name": name,
            "value": value,
            "appraisable": isAppraisable,
            "color": color
        })

    return rows

def save_clean(data):
    CLEAN_FILE.parent.mkdir(parents=True, exist_ok=True)

    with open(CLEAN_FILE, "w", encoding="utf-8") as f:
        json.dump(data, f, indent=2, ensure_ascii=False)

def getData():
    # START OF THE PROGRAM
    #if CLEAN_FILE.exists():
        #CLEAN_FILE.unlink()
    if CLEAN_FILE.exists():
        print("loading mutation data from local (delete local if out of date)")
        with open(CLEAN_FILE, "r", encoding="utf-8") as f:
            data = json.load(f)
    else:
        if RAW_FILE.exists():
            print("Loading from local (delete local if out of date)")
            with open(RAW_FILE, "r", encoding="utf-8") as f:
                raw_data = json.load(f)
        else:
            raw_data = fetch_and_save()
        # clean data after fetching
        data = extract_mutations(raw_data)
        save_clean(data)
    return data


if __name__ == "__main__":
    data = getData()
    print(data)